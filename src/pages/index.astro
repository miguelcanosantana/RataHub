---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout>

    <!-- Hero -->
    <div class="flex items-end justify-center bg-cover bg-center relative" 
        style="min-height: calc(100dvh - var(--navbar-height)); background-image: url(https://cdn.pixabay.com/photo/2016/05/10/15/39/rat-1383998_1280.jpg); filter: brightness(0.85) saturate(0.85);">
        
        <div class="bg-base-200/90 p-6 rounded-3xl text-base-content mb-4 max-w-2xl">
            <h1 class="text-3xl font-bold mb-4">Todo sobre tus ratitas</h1>
            <p class="text-lg leading-relaxed">En este sitio encontrarás las mejores recomendaciones de productos en España para el cuidado de tus ratitas.
            <br>También qué tener en cuenta si eres primerizo con ellas 🧑🏽❤️🐀</p>

            <div class="mt-4 mx-4 flex gap-2 justify-center">
                <a class="btn btn-secondary" href="#intro">Introducción</a>
                <a class="btn btn-primary" href="#categorias">Explorar Categorías</a>
            </div>

        </div>
    </div>

    <!-- Intro -->
    <div id="intro" style="min-height: calc(100dvh - var(--navbar-height));">
        
    </div>

    <!-- Categorías -->
    <div id="categorias" class="w-full flex flex-col" style="min-height: calc(100dvh - var(--navbar-height));">

        <div class="grid grid-cols-1 md:grid-cols-2 grid-rows-2 gap-6 p-8 flex-1">

            <a href={`${base}guia-compra/`} class="bg-primary text-primary-content flex items-center justify-center rounded-4xl p-8 text-center shadow-lg hover:scale-[1.01] transition-transform border-4 border-transparent">
                <p class="text-4xl md:text-6xl font-bold leading-tight">Guía de compra</p>
            </a>

            <div class="bg-base-200 text-base-content/30 flex items-center justify-center rounded-4xl p-8 text-center border-4 border-dashed border-base-300">
                <p class="text-4xl md:text-5xl font-bold uppercase tracking-widest">En desarrollo</p>
            </div>

            <div class="bg-base-200 text-base-content/30 flex items-center justify-center rounded-4xl p-8 text-center border-4 border-dashed border-base-300 md:col-span-2">
                <p class="text-4xl md:text-5xl font-bold uppercase tracking-widest">En desarrollo</p>
            </div>
            
        </div>
    </div>

</Layout>
