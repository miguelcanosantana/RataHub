---
import ItemMiniature from '../components/ItemMiniature.astro';
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const recommendedItems = await getCollection('recommendedItems');

---

<Layout>
	<!-- <Welcome /> -->

	{recommendedItems.map((i: any) => (
		<ItemMiniature item={i}></ItemMiniature>
	))}
	
</Layout>

