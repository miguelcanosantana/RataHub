---

const { item } = Astro.props

---

  <div class="card bg-base-100 shadow-none border-2 border-base-300">
    <div class="card-body">
      <h2 class="card-title">{item.data.name}</h2>
      <p>This is inside a grid column.</p>
      <div class="card-actions justify-end">
        <button class="btn btn-neutral">Comprar</button>
      </div>
    </div>
  </div>

  